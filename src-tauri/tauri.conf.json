{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZAFControl",
  "version": "0.1.0",
  "identifier": "com.zaf.control",
  "build": {
    "frontendDist": "../dashboard/dist",
    "devUrl": "http://localhost:4242",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZO Agentic Framework Control",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
