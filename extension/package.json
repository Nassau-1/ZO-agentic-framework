{
  "name": "zaf-control",
  "displayName": "ZAF Control",
  "description": "ZAF (Zero-to-one Agent Framework): live ticket board, PTY shells, gutter indicators",
  "version": "2.1.0",
  "publisher": "nassau-1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zaf-explorer",
          "title": "ZAF",
          "icon": "resources/zaf-icon.svg"
        }
      ]
    },
    "views": {
      "zaf-explorer": [
        {
          "type": "webview",
          "id": "zaf.board",
          "name": "Board"
        },
        {
          "type": "webview",
          "id": "zaf.shells",
          "name": "Active Shells"
        },
        {
          "type": "webview",
          "id": "zaf.audit",
          "name": "Audit Log"
        }
      ]
    },
    "commands": [
      {
        "command": "zaf.openPanel",
        "title": "ZAF: Open Panel"
      },
      {
        "command": "zaf.launchAgent",
        "title": "ZAF: Launch agent on current ticket"
      },
      {
        "command": "zaf.refresh",
        "title": "ZAF: Refresh"
      }
    ],
    "keybindings": [
      {
        "command": "zaf.openPanel",
        "key": "ctrl+alt+z",
        "mac": "ctrl+alt+z"
      }
    ],
    "configuration": {
      "title": "ZAF",
      "properties": {
        "zaf.sidecarUrl": {
          "type": "string",
          "default": "http://localhost:4242",
          "description": "ZAF sidecar server URL"
        },
        "zaf.autoStartSidecar": {
          "type": "boolean",
          "default": false,
          "description": "Auto-start the sidecar server on extension activation"
        },
        "zaf.defaultHarness": {
          "type": "string",
          "enum": ["mock", "zaf", "claude-code", "codex", "gemini-cli"],
          "default": "mock",
          "description": "Default CLI harness for agent launches"
        }
      }
    }
  }
}
